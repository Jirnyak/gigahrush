{
  "entries": {
    "gt_7f6d6f0a09de32": "Target down.",
    "gt_43057c8313c78d": "Write it off in the log.",
    "gt_f7125a7462af31": "Passage clear.",
    "gt_2403b5b4f4715f": "Orderlies, here.",
    "gt_d8338730ed12e2": "Contact closed.",
    "gt_73b315d2098444": "Check the filters.",
    "gt_8b33f10164a6dc": "Body to the wall, sector next.",
    "gt_42d4216c06cf77": "Report after the sweep.",
    "gt_596bbfe701b8d3": "The sack's ours.",
    "gt_18c4e73bec9ca0": "Got quieter.",
    "gt_1133340c755b49": "Bread's safe.",
    "gt_f577effb1ef8e6": "Don't touch the pot.",
    "gt_da0c4e0afe7cd0": "Check the pockets.",
    "gt_ddd8e83afbacb4": "Take the shoes.",
    "gt_057d337af82042": "Not asking anymore.",
    "gt_1cdd1f89c26a5f": "Didn't sell out his own.",
    "gt_cb4637aca4de27": "Shouldn't have crawled into the flat.",
    "gt_abd95834bb1582": "Close the door now.",
    "gt_83253afeeb12d4": "Kitchen's free.",
    "gt_6bf65d924211c0": "Take his keys.",
    "gt_ed95697741ea6a": "We'll tell the neighbors he came at us.",
    "gt_448f04e01c5153": "Check the coupons.",
    "gt_cc290045252369": "Get it away from the kids.",
    "gt_1e7973856f8a2d": "Close the door before the noise starts.",
    "gt_08abdb12753985": "Spot by the radiator opened up.",
    "gt_d150baeed459c2": "The list got shorter.",
    "gt_98c9c3aa4a0fa2": "Didn't burn that candle for nothing.",
    "gt_701fd9c2ed64cf": "Strip his ration.",
    "gt_ee69793e697ca0": "Quiet, the neighbors haven't cleared out yet.",
    "gt_3040ad03da520e": "Carry him away from the mark.",
    "gt_60bb2e3b04bb48": "The door closed behind him.",
    "gt_a97245781f6002": "Nobody argues after all-clear.",
    "gt_e785657d7f226f": "Debt paid in things.",
    "gt_fb753a8cbab86e": "Goods are intact.",
    "gt_38e0d526ebb99d": "Queue moves on.",
    "gt_88d2f0e9316ac2": "Cash desk closed.",
    "gt_687eaec4311322": "Check his backpack.",
    "gt_8c1c6c3eacfc48": "Came out with no change.",
    "gt_24c313bb9ce1f8": "Storage is mine again.",
    "gt_d82894758c5487": "Learned the price too late.",
    "gt_77ed826b0821e1": "Aa!..",
    "gt_f388e9428a6992": "Hurts like fuck!",
    "gt_92e22cb2d39c68": "They clipped me!",
    "gt_0d5931a598e3c6": "Wounded!",
    "gt_b8cd32c1ca18a3": "Bad...",
    "gt_5450f6fe413e59": "Bastards!",
    "gt_ca43dabb204513": "Need help...",
    "gt_0a83a03969681b": "This is it...",
    "gt_935961e10eec16": "Ow, fuck!",
    "gt_64da6f263e388f": "Damn, it punched through!",
    "gt_6e6865bba3cbea": "Hit me, bastard...",
    "gt_632a6aef4d107c": "Blood's flowing...",
    "gt_ea8ee9c0d85c1f": "I'm hit!",
    "gt_dd763938cc8ad5": "Stomach... fuck...",
    "gt_9b285b0a1cc43b": "Shoulder's torn up!",
    "gt_ebcb0b16bdc850": "Motherfucker, that hurts!",
    "gt_7b8f229e42cc38": "Leg's gone!",
    "gt_b303c526d9f12f": "Can't hold on...",
    "gt_3bb790dbd7d529": "Medic here!",
    "gt_c83e7956a4084c": "Caught a slug!",
    "gt_b89d3416001233": "Nearly spilled my guts...",
    "gt_f505daba9e0f66": "Damn you...",
    "gt_f10c6f4993a5f0": "I'm done like this...",
    "gt_fecb9cdeb13568": "Don't leave me...",
    "gt_3557762ad3882d": "Lung, I think...",
    "gt_e031f3f96e9ddc": "Rib cracked...",
    "gt_cc929bdfa8fa56": "Hard to breathe...",
    "gt_8d8b1d4051c616": "Shit, it burns...",
    "gt_bb5afe4536b37b": "I'm about to drop...",
    "gt_a30d3883c5f831": "Wrap me up...",
    "gt_fe6491b9b163b6": "Bad... real bad...",
    "gt_c1d65db2fe2654": "Caught it, caught it!",
    "gt_1becfc31d6a031": "I can't take this...",
    "gt_eefe3b72a77228": "Why's it hurt so bad...",
    "gt_af0280129db9af": "Arm's hanging...",
    "gt_aab9a4c6255f8b": "I'm about to die...",
    "gt_6746d696fb76e7": "Went in deep...",
    "gt_8addc195829238": "Bone cracked, I think...",
    "gt_e3f488569239d8": "Everything went dark...",
    "gt_5f4d232e82ac17": "I'm swaying...",
    "gt_76374bce021353": "Can't breathe in...",
    "gt_cf17d3bcb1800c": "Brothers, finish them...",
    "gt_83349d99d5416d": "Get me out of here...",
    "gt_3b07e5e0bbc128": "Bastard hit me...",
    "gt_075f2fd09b6b36": "Side's burning...",
    "gt_2692b3cee238fe": "Back's punched through...",
    "gt_ab55612e8288a8": "Fuck living like this...",
    "gt_ef532052877e85": "I'm going down...",
    "gt_5c3c743f01d440": "Blood's flooding me...",
    "gt_971d4d1d243029": "Damn, legs are gone soft...",
    "gt_757305623974e1": "Head's swimming...",
    "gt_479c25a03c4f96": "Pinned me down, fuck...",
    "gt_2d50a11df18595": "Almost finished...",
    "gt_dd9de5d01d1604": "Could use a bandage...",
    "gt_dc1712ed6d541c": "I'm about to collapse...",
    "gt_24545ea728c0df": "Hurts so bad it's going dark...",
    "gt_901963cf0b4f8f": "Got me bad...",
    "gt_9ba3f584f3a567": "I'm not making it...",
    "gt_8de481fbd86e7b": "I'm coming apart...",
    "gt_58a4b72069a440": "Can't feel my fingers...",
    "gt_b3fa6c7aa3ec6c": "Went deep in the side...",
    "gt_367f012afab57f": "Shit, it's lodged deep...",
    "gt_8e192b77a31c19": "Damned section...",
    "gt_073ba63350e3f9": "I'm bleeding out...",
    "gt_e752f09a9a7568": "Can't stand straight...",
    "gt_373117b5f7ba74": "Boys, cover me...",
    "gt_d7314d880c03b7": "A little more and that's it...",
    "gt_16c6088b127eab": "It's breaking me...",
    "gt_8cc736c1c3b226": "Straight through, maybe...",
    "gt_52b96a8b7a2c69": "Heart's about to jump out...",
    "gt_9011222fd6be7f": "Heat all through me...",
    "gt_e42e4f578732b9": "Don't leave me, hear me...",
    "gt_fc836e4ee773a1": "I'm falling apart...",
    "gt_b4d550f71cac64": "Punched through like a tin can...",
    "gt_b2e6dd493b5796": "Pressure's dropping...",
    "gt_474fc4bbfcea6f": "Where the fuck's the medic...",
    "gt_3cb6815ded94d5": "I'm soaked in blood...",
    "gt_3277cbba7520ec": "Patch me up somehow...",
    "gt_2df96628edb1ad": "Seeing double...",
    "gt_369669edd3b500": "I'm about to black out, damn it...",
    "gt_a0f1f1ade26a40": "Hold the line without me...",
    "gt_a780973686d3ae": "I'm in a real bad way...",
    "gt_34e1aac2d672fc": "Knees won't hold...",
    "gt_862f3281a9de64": "Hurts so bad I'm sick...",
    "gt_263774d4828ea1": "I'm going to the floor...",
    "gt_6175a62f732250": "Not here...",
    "gt_9c7ffd475dccbd": "Hey, don't let me croak...",
    "gt_9468bdb274bfbe": "Everything inside is burning...",
    "gt_42bf193105fea7": "They opened me right up...",
    "gt_c3b5cabb0c72af": "Almost no air...",
    "gt_7430eca67f1e79": "Blood won't stop...",
    "gt_6e7c8dfca179af": "Can't feel half my body...",
    "gt_e14b4952e97b4f": "I'm about to drift all the way out...",
    "gt_3e76de5e2f3349": "Bastards stuck it in deep...",
    "gt_8b62a2a740a4ac": "Shaking all over...",
    "gt_3a5a8bacd985d6": "Need a tourniquet, quick...",
    "gt_3d5d788aad1adb": "World's rocking...",
    "gt_3b3afa86e336cd": "That's it, I'm sinking...",
    "gt_9cb016073854d9": "Press the wound, now...",
    "gt_05d416f108ba54": "I'm about to go out...",
    "gt_9b0d4475b6e881": "Ow!..",
    "gt_6c2a1d7868e965": "It hurts!",
    "gt_6ee089eecf85e0": "I'm wounded!",
    "gt_617f53a3acd7e9": "Help...",
    "gt_d16b394cd9ecba": "Oh, mama!",
    "gt_01ed77630e74a2": "It hurts so much!",
    "gt_3f99a3638b07ba": "Damn, they hit me!",
    "gt_14a51639e466a8": "It punched through...",
    "gt_1d0177223edb23": "Blood's running...",
    "gt_ada6603fb91a87": "Can't stand...",
    "gt_b938d7284be6a2": "Shoulder... fuck...",
    "gt_d923e317614385": "Shot in the stomach...",
    "gt_530ef7077973b2": "Medic, quick!",
    "gt_a354fcae4d0872": "I'm very bad...",
    "gt_53c6053d7a488c": "Lord, it hurts...",
    "gt_9e4a6b56245a08": "I can't breathe...",
    "gt_5361193c199056": "Arm's hit...",
    "gt_f9bfbfc6cc8c8b": "I'm about to fall...",
    "gt_5b9071dc8e149b": "They got me hard...",
    "gt_51801f6490472f": "Help me, please...",
    "gt_bdf25608d7c9bd": "I can't hold on...",
    "gt_0e93c140a3b77a": "Rib, I think...",
    "gt_c79cdb053a6446": "I'm torn up...",
    "gt_3bf77d9a04c4bd": "Losing strength...",
    "gt_097d6cf968ed3c": "I'm finished...",
    "gt_30dff7fb090d05": "Hurts so much...",
    "gt_15e2ea72365d59": "I'm covered in blood...",
    "gt_7daddb7385020f": "Don't leave me here...",
    "gt_1186958faa9e88": "Bastards got me...",
    "gt_9273aec0d7301f": "It's going dark...",
    "gt_211b2340ffaf87": "I can't feel my arm...",
    "gt_98fc527dcf1e8d": "Went clean through, I think...",
    "gt_2c3ef9861fd3d0": "I'm terribly bad...",
    "gt_d80ca6ff20d2f4": "I can't stay up...",
    "gt_3c718bfe68f743": "Cover me...",
    "gt_19b3f06581fe59": "Get me out of here...",
    "gt_ebcc3fa9988fc0": "Legs are buckling...",
    "gt_4eacfeae0a7339": "Stomach's burning...",
    "gt_c404e1a4ac4451": "It went too deep...",
    "gt_2a33c64dd1b751": "I'm bleeding out..."
  }
