{
  "locale": "en",
  "notes": "Worker B1 EN barks batch: source-order todo slice from src/systems/ai/barks.ts, ending at the trader combat bark block.",
  "entries": {
    "gt_b971450222cc70": "Here! Enemy!",
    "gt_eea471fb99458e": "Hit him!",
    "gt_4ed283d07881e1": "That's it, you're done!",
    "gt_ad101054c142ff": "I'll show you!",
    "gt_69c667b2c0dd78": "Got you!",
    "gt_db14944e096cd5": "Come here!",
    "gt_e8e129c3f5bdfb": "You asked for it!",
    "gt_eb4306fefc0908": "This will hurt!",
    "gt_dcdd723f308794": "Stop, bastard!",
    "gt_53b5b3fa6fb901": "Hands off the wall. Come here!",
    "gt_1d7d7dfb2353e6": "Wrong place.",
    "gt_170a8679ee4cf5": "Your shift is over.",
    "gt_0094f41d080f0c": "You won't leave alive.",
    "gt_0e7023cb38c238": "Target in sight!",
    "gt_05d80d24a795c8": "Target in sector!",
    "gt_e51f9223c55ab9": "Two left, hold the pipe!",
    "gt_4e6dd0703753a3": "Wounded to the rear!",
    "gt_990a985db0007b": "No retreat!",
    "gt_4855cb0530583d": "You! On the floor!",
    "gt_c893542fb64d73": "I'll settle you down.",
    "gt_7cdb171c6f471d": "Out of the shadow!",
    "gt_2d43f7d110c83e": "Don't twitch!",
    "gt_bda645a64fce21": "Get out of here!",
    "gt_2ecb871c52a2c4": "Take this, freak!",
    "gt_ad4d0de035de44": "We'll settle this nice and proper.",
    "gt_5af1bfce577389": "Strays in the section again.",
    "gt_339f1498810260": "One step aside and I shoot!",
    "gt_aafe272daf9c9e": "There you are, bastard.",
    "gt_9918e130e5fd0f": "This will be a short talk.",
    "gt_7181546b5edd16": "So you showed up.",
    "gt_a02053aa6216b6": "Stop while you're whole.",
    "gt_3343e45acf4c22": "It's on, fucker.",
    "gt_45b2f6288ab92a": "Bad time to barge in.",
    "gt_f03bc767b62e1e": "Didn't get it the nice way?",
    "gt_9ab985145b5f7e": "Put him to the wall!",
    "gt_f32cf78ca03869": "Nobody expected you here.",
    "gt_13ce031177f6ae": "Face down. Now.",
    "gt_8a9e134fd1afbb": "Cut him down!",
    "gt_27483fe3d8d993": "Armed target!",
    "gt_0a685667c089c2": "Don't let him close!",
    "gt_15a34100fd711f": "Work the target!",
    "gt_69a2be74c37556": "Stand still, scum!",
    "gt_d999d59b32570f": "You're going down.",
    "gt_87b867c4ba69ac": "Shouldn't have come out.",
    "gt_481969f4ee5a04": "So you barged in.",
    "gt_fa46cbf71521d2": "Move and it's over.",
    "gt_b8243787a4096d": "Don't ruin my day.",
    "gt_147edb1557f3f8": "Should've listened first time.",
    "gt_1980af50fc2ff3": "Nobody's glad to see you.",
    "gt_dfc59d5cb888ed": "This corridor isn't yours.",
    "gt_85eb008ca0636e": "Work starts.",
    "gt_fd3a6468b585c5": "I'll knock the stupid out.",
    "gt_a00e6b0a6753bc": "Take him!",
    "gt_093256e474089f": "Target in the passage!",
    "gt_a26b79a4fb35e9": "Pin him to the wall!",
    "gt_e5178535feb3f3": "Light the target!",
    "gt_7505360545fec0": "Stop, freak!",
    "gt_1ccf2c4ad4f3e8": "Time to pay.",
    "gt_e41033444b6054": "Shouldn't have pushed in.",
    "gt_234d15ada40576": "Sector's ours, got it?",
    "gt_7cf503c727dde0": "Stay out of another block.",
    "gt_220e6df3e6d767": "We'll process you now.",
    "gt_d59998457ba49b": "Hold the passage!",
    "gt_eeccb4992d7c6a": "Drop him!",
    "gt_8b7285b9bcab54": "Pinned him, finish it!",
    "gt_a6c91856a48b85": "You're about to catch it.",
    "gt_e926b3c2656194": "Step out and lie down!",
    "gt_03f8bae8c40c18": "Hey, back up!",
    "gt_f8991a9d873f55": "Don't play hero.",
    "gt_07da19c94f1bd4": "Picked your moment, huh?",
    "gt_740e69ab569eed": "This isn't a public passage.",
    "gt_23a59b4086f760": "Come here. We need to talk.",
    "gt_17e0b554c2b26b": "No time to regret it.",
    "gt_48756807cd254b": "I'll smear you on the floor.",
    "gt_3a39c082ce5826": "Get out while you're whole.",
    "gt_bd5e5f99394268": "Moving! Drop him!",
    "gt_31bc916914d518": "Fire on the stranger!",
    "gt_8825166eee80d7": "Too late for you to back out.",
    "gt_1bacd54a0271fa": "You'll stay here.",
    "gt_d565af5a819689": "Stand quiet. Don't twitch.",
    "gt_ef3ded5657c06a": "This ends fast.",
    "gt_3147dae3eedd00": "Wrong turn.",
    "gt_4c87201fefafa8": "Break his plan.",
    "gt_3a882fa40b7c19": "Fire down the passage!",
    "gt_2c8a995f38f419": "Don't let him go!",
    "gt_73e6fda264561d": "I see right through you.",
    "gt_b3fd35a29d1039": "Where are you going? Back!",
    "gt_ed6f2ec9ad0b49": "This block has its rules.",
    "gt_25000dcb3c172c": "We'll explain it now.",
    "gt_400ee8671f5357": "Put him on the floor.",
    "gt_98e086f828a72e": "Stranger in the corridor. Work!",
    "gt_4b86631ccc82d0": "Didn't get away.",
    "gt_9709baee36c91d": "Picked up a gun? Now answer.",
    "gt_535cc3adc365cb": "Shouldn't have gone at people.",
    "gt_c85739cdc45c30": "Cocky ones don't leave here.",
    "gt_700ad63c1a4d55": "Keep him from the door.",
    "gt_76f10d1f27f9c5": "We'll cool you off.",
    "gt_2c333df1f010fc": "We'll drop him fast.",
    "gt_1673557ac7e76e": "Don't break order.",
    "gt_d40ccdd8fbdd70": "We'll strip you and lay you out.",
    "gt_ee003a73b3335d": "All noise, no use.",
    "gt_ea7d110edb18a7": "We'll seal you in the sector.",
    "gt_e062718013cfc3": "Come on, step into the light.",
    "gt_5f43da4db75d45": "You'll get the full measure.",
    "gt_67e538fa3f2692": "Stop! Don't move!",
    "gt_1969e18e238705": "That's it, I'll handle it myself!",
    "gt_14d1b80a2735b3": "Don't touch me!",
    "gt_08159e96dd72a2": "You beast!",
    "gt_99a89e1b63533a": "Take that!",
    "gt_63bec7b3fd0c09": "Back up!",
    "gt_7a7b7ceca70a4e": "Don't come near me!",
    "gt_b6fc352d23c1ef": "I'll put you down.",
    "gt_373df97401d363": "Hands off!",
    "gt_dce88e0136b862": "You shouldn't have shoved in here.",
    "gt_48df7e282f6332": "I see you!",
    "gt_efcac53b066b0e": "Two left, hold the pipe!",
    "gt_e750fe3e696c27": "Stop, scum!",
    "gt_9f818c0eabaf9c": "You're getting it now!",
    "gt_fd47f549c2bffa": "Face to the floor!",
    "gt_2b25c0e3541a46": "One more step and I shoot!",
    "gt_6a3a6cf5e18c79": "Don't twitch, hear me?",
    "gt_15438b3def99aa": "Filth...",
    "gt_e8b86295f9cdf8": "You're done.",
    "gt_653251eda93a08": "I'm not your victim.",
    "gt_8379d306931145": "I'll finish you myself.",
    "gt_ea52efaa2b5e97": "You came to the wrong address.",
    "gt_aa9861a9f0ec5e": "Stop hiding, come out!",
    "gt_bbf493e3edfd56": "Cut him down!",
    "gt_f605201fbf8ee3": "Don't move!",
    "gt_17ee05d987bcd6": "This will hurt, got it?",
    "gt_028c90ae5935a8": "I warned you.",
    "gt_1b0e2b5fab6639": "Don't come at me!",
    "gt_b0035ad46cea35": "Wrong woman to rush.",
    "gt_696c3d9b8e5df2": "Come on, come here.",
    "gt_44ad77f085aceb": "I'll knock that swagger out.",
    "gt_71b62bc6672ad6": "Stranger in sector!",
    "gt_ee33e73e78d95c": "Engage!",
    "gt_76ae6a38c3f9c7": "Stay where you are!",
    "gt_b67548df6db778": "You'll go down and shut up.",
    "gt_1db1a22292a2de": "Don't ruin my shift.",
    "gt_71251b0c2104d2": "You weren't expected here.",
    "gt_f1ad1d2c30d9d7": "Didn't get it nice the first time?",
    "gt_9d47dd3af54984": "Step away from the door!",
    "gt_4d7f93be69831f": "I'll beat the stupid out of you.",
    "gt_939da14a10768f": "Target by the passage!",
    "gt_ecad04c167ce86": "Hold him!",
    "gt_11e6d1a741f423": "Don't play hero.",
    "gt_55c9ceb376e7f9": "Look here!",
    "gt_ef591615bbe4a1": "We'll process you now.",
    "gt_ff8b3f38f4c045": "Too cocky.",
    "gt_4e3fd3acc408c2": "You'll catch yours.",
    "gt_1e180ff60acf08": "Touch me and die.",
    "gt_5ba367a4617c2d": "This isn't a market.",
    "gt_7b5ebc6b16a190": "Step back. Fast.",
    "gt_e7b39d8aeadd11": "You're in the wrong block.",
    "gt_4c6272a326510c": "Light the target!",
    "gt_865986e8f4d3ad": "I'll pin you.",
    "gt_757af788e32169": "You're not going anywhere.",
    "gt_573073dfee43ce": "Get out while you breathe.",
    "gt_dd61313162edc5": "Don't you come at me.",
    "gt_b4948d480a27e2": "Work him!",
    "gt_e2cb645318d83b": "I'll calm you for good.",
    "gt_fcaf338aa8386d": "Too late to go back.",
    "gt_71bf00ab82561d": "Stay out of our sector.",
    "gt_c394f2e18c75f4": "You'll stay here.",
    "gt_4a06d649ada31f": "Bad time to crawl out.",
    "gt_090af6b0bd4e5a": "I'll smear you on the floor.",
    "gt_7f13577b885f79": "Get out while you're whole.",
    "gt_b14d9f5cdee05a": "You're finished.",
    "gt_e136fb0cdaf714": "Put a gun on him!",
    "gt_0f7a6c04649d74": "Stand quiet. Don't move.",
    "gt_39195afe32862f": "This will end fast.",
    "gt_61a6067e5b1842": "Break his whole plan.",
    "gt_06d101e2d80a3c": "Don't let him go!",
    "gt_4b6dbee4e4700b": "I see right through you.",
    "gt_c2a19865fdddc4": "We'll explain everything now.",
    "gt_49e9657b7c9e70": "On the floor with him.",
    "gt_726e3de6fe842e": "Stranger in the corridor. Engage!",
    "gt_dbef9435e653c7": "Cocky ones don't leave here.",
    "gt_6f3eb423590965": "Keep him from the door.",
    "gt_940670ae6ccefb": "I'll cool you off.",
    "gt_67215ee567b773": "Friendlies right, muzzle down!",
    "gt_8614481520dace": "Target in the wet passage!",
    "gt_1a26e208eccbbf": "No freelancing!",
    "gt_cda72b1c5bb583": "Keep it off the door!",
    "gt_47be0c1ab64c7e": "Report after contact!",
    "gt_01e8ed62ae0c3e": "Save the second magazine!",
    "gt_024672f11c72a0": "Hold the dry edge!",
    "gt_8a7e547b97bad4": "Eye's heating - around the corner!",
    "gt_eeaab8b3d1dd2f": "Don't hold a Crawler in the door!",
    "gt_30fefdaff6ddaf": "Rebar's ringing - don't step!",
    "gt_c8af7b1de5ad5c": "Lamp-thing off the lamp!",
    "gt_7629e17417c675": "Don't bring the Stamp-Eater papers!",
    "gt_007d531d53a0dc": "Bonecutter winds up - three steps!",
    "gt_c68cf3a50821d6": "Shadow into the light!",
    "gt_bdd20949f08fe2": "Eel in water - get to the edge!",
    "gt_34e1faf312288e": "Shovnik to the room center!",
    "gt_d8cdad95f1deff": "Paragraph shoots straight!",
    "gt_53fbcd29d6a769": "Stay away from the kitchen!",
    "gt_ecfc8cfdffdb05": "Noisy one came!",
    "gt_93f5501b7237e3": "Knife will be quieter!",
    "gt_4cc85a1a535bbb": "Go around while you're whole!",
    "gt_c17e7de6950dea": "We don't give up our own!",
    "gt_686346940c5424": "Save the bullet, sack on the floor!",
    "gt_79dd4ca8c95c4a": "Name later, food on the floor!",
    "gt_4fb9502caf0528": "The pot's ours. Your way is back!",
    "gt_b0dc42b8a5bc38": "Bread on the floor, you to the door!",
    "gt_f824b21508a859": "Step away from the door!",
    "gt_7f983e00952ae3": "Don't touch our cupboard!",
    "gt_ee9633774faace": "I won't give up the keys!",
    "gt_6e87143ecde4ac": "Neighbors, here!",
    "gt_2f763cda4c0617": "Don't touch the kitchen!",
    "gt_6ba432728f8d5b": "You cut into the wrong queue!",
    "gt_55eae18d7b2230": "My kids are behind that wall!",
    "gt_9343ddc9a5d138": "I'll hit you with the pot!",
    "gt_77630a27f0b2a0": "Back out of the section!",
    "gt_94cf70d038096d": "Coupons on the floor and out!",
    "gt_a8b14026257585": "Don't mess with our hermodoor!",
    "gt_cbfff18fd88ce4": "Away from the storeroom!",
    "gt_800073e06735fb": "Don't trample the mark!",
    "gt_6b2c494b3601e3": "Leave the rations by the door!",
    "gt_1b71f7bc73c539": "The Black Circle did not record you!",
    "gt_1c93de5e245539": "Keep quiet by the candles!",
    "gt_6d2e104c31c915": "To the radiator with him. We'll sort it there!",
    "gt_a75398e6095d36": "You're a stranger on our list!",
    "gt_ccdcbb127acc99": "Hands off the common bread!",
    "gt_e4d10456e0222a": "You were told to close the door, not argue!",
    "gt_eeb6aacc1a37cf": "Don't break our corner!",
    "gt_d5dfc18509b76f": "Knock down a candle, lie down yourself!",
    "gt_f428bf4c999d9f": "After all-clear, your kind stays out!",
    "gt_c87c693ea61b91": "Quiet him before the neighbors hear!",
    "gt_8bcca636a045be": "Back from the counter!",
    "gt_814a3b6467c9be": "Don't touch the coupon box!",
    "gt_7087486b0714c1": "Price first, hands after!",
    "gt_f8c6811ed9b9ad": "Debt on the floor and to the wall!",
    "gt_ce993f29d0e8cc": "Don't hit the display. You won't afford it!",
    "gt_4e1b4fd0f8745b": "Till's closed. Now I'll close you.",
    "gt_ac0878f9040497": "Opened the backpack, your fault!",
    "gt_64a39c0a01c3de": "The warehouse isn't a public passage!",
    "gt_752425fc3decee": "Counted the rounds? We'll recount!",
    "gt_88bdb56b68a63c": "You'll leave with no change!",
    "gt_6a6497eac86a98": "Goods are mine, bruises are yours!",
    "gt_150f97b548639d": "Queue, grab the thief!"
  }
}
