+
+function isAdult(snapshot: AlifeNpcSnapshot): boolean {
+  return snapshot.age >= 18;
+}
+
+function buildBuckets(snapshots: readonly (AlifeNpcSnapshot | undefined)[], total: number): DemosSocialBuckets {
